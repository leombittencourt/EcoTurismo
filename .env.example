# ==========================================
# Variáveis de Ambiente - EcoTurismo API
# ==========================================
# Copie este arquivo para .env e preencha os valores

# ==========================================
# DATABASE
# ==========================================
DB_CONNECTION_STRING=

# ==========================================
# JWT (JSON Web Token)
# ==========================================
# Gere uma chave forte de 256 bits (32 bytes)
# Exemplo de geração: openssl rand -base64 32
JWT_SECRET_KEY=

# ==========================================
# API KEYS
# ==========================================
# Chaves para validação de requisições públicas
# Gere chaves únicas para cada aplicação (Web, Mobile, etc)
# Exemplo de geração: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='

# Chave para o frontend web
API_KEY_WEB=sua-chave-web-aqui

# Chave para o app mobile
API_KEY_MOBILE=sua-chave-mobile-aqui

# ==========================================
# OPCIONAL: Adicione mais chaves se necessário
# ==========================================
# API_KEY_INTEGRACAO=sua-chave-integracao-aqui
# Para usar: adicione no docker-compose.yml:
# - ApiKeys__ValidKeys__2=${API_KEY_INTEGRACAO}
s